  "calculation_helpers": {
    "recommended_max_threads_formula": "(cpu_cores - 2) * 10",
    "recommended_connection_count_formula": "min(server_max_connections * 0.8, client_threads * 1.5)",
    "ram_overflow_dataset_size_formula": "server_ram_gb * 1.5 * 1000000 / 1024",
    "thread_to_cpu_ratio": {
      "light": "cpu_cores * 2",
      "medium": "cpu_cores * 4",
      "heavy": "cpu_cores * 6",
      "extreme": "cpu_cores * 10"
    }
  }
