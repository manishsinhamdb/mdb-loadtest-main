          "params": {
            "threads": 4,
            "target_ops_per_sec": 0
          }
        },
        "unindexed_scans": {
          "enabled": false,
          "params": {
            "threads": 4,
            "target_ops_per_sec": 0
          }
        },
        "inmemory_sorts": {
          "enabled": false,
          "params": {
            "threads": 4
          }
        },
        "aggregation_pipelines": {
          "enabled": false,
          "params": {
            "threads": 4,
            "complexity": "medium"
          }
        },
        "write_bursts": {
          "enabled": false,
          "params": {
            "threads": 4,
            "batch_size": 100,
            "doc_kb": 10
          }
        },
        "update_contention": {
          "enabled": false,
          "params": {
            "threads": 4,
            "hot_doc_count": 100
          }
        },
        "mixed_blend": {
          "enabled": false,
          "params": {
            "threads": 12,
            "seed": null
          }
        }
      },
      "seeding_requirement": "configurable",
      "seeding_params": {
        "large_count": 1000000,
        "agg_count": 50000,
        "hot_docs": 100
      },
      "primary_metrics": [],
      "secondary_metrics": [],
      "calculation_formulas": {},
      "intensity_multipliers": {
        "light": 1.0,
        "medium": 1.0,
        "heavy": 1.0,
        "extreme": 1.0
      },
      "resource_estimates": {
        "client_cpu_percent": "varies",
        "client_ram_mb": "varies",
        "server_cpu_percent": "varies",
        "server_ram_gb": "varies",
        "network_mbps": "varies"
      },
      "recommended_duration_seconds": 600,
      "warnings": [
        "Manual configuration - user is responsible for parameter tuning",
        "No automatic resource validation - override limits at your own risk",
        "Metric impact predictions not available in custom mode"
      ]
    }
  },
  "global_settings": {
    "default_intensity": "medium",
    "default_duration_seconds": 600,
    "default_data_size": "1m",
    "default_concurrency_level": 10,
    "min_duration_seconds": 60,
    "max_duration_seconds": 86400,
    "min_threads_per_workload": 1,
    "max_threads_per_workload": 1000,
    "thread_safety_multiplier": 10,
    "ram_safety_margin_percent": 20
  }
}
